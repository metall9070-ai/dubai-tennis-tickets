# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# Multi-site platform — Next.js Frontend
# =============================================================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to git - it contains secrets!
# =============================================================================

# =============================================================================
# SITE IDENTITY (Required)
# Each deployment MUST have its own site_code and site_url.
# These drive site-config, SEO, metadata, and analytics isolation.
# =============================================================================
# Site code — selects config from SITE_CONFIGS (e.g. "tennis", "finalissima")
NEXT_PUBLIC_SITE_CODE=tennis

# Canonical domain — used for metadataBase, canonical URLs, og:url
# MUST match the actual deployment domain (SEO_ARCHITECTURE v1.7 §3B)
NEXT_PUBLIC_SITE_URL=https://dubaitennistickets.com

# =============================================================================
# DJANGO API CONFIGURATION
# =============================================================================
# Production backend URL (Railway)
NEXT_PUBLIC_API_BASE_URL=https://worthy-clarity-production.up.railway.app

# Django shadow mode (false = API controls UI, true = only logs for comparison)
NEXT_PUBLIC_DJANGO_SHADOW_MODE=false

# Which events use live Django prices (* = all, or comma-separated IDs: 1,2,3)
NEXT_PUBLIC_DJANGO_LIVE_EVENT_IDS=*

# =============================================================================
# STRIPE PAYMENTS (Frontend needs publishable key only)
# =============================================================================
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_... for testing, pk_live_... for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# =============================================================================
# ANALYTICS (Per-site — ANALYTICS_CANON.md strict isolation)
# Each deployment MUST have its own analytics IDs.
# Shared IDs between sites are FORBIDDEN.
# Missing value = no script injected (safe no-op).
# =============================================================================
# Google Analytics 4 — Measurement ID from GA4 property
# Get from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager (optional) — Container ID
# Get from: https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Search Console — HTML tag verification token
# Get from: https://search.google.com/search-console → Settings → Ownership verification
NEXT_PUBLIC_GSC_VERIFICATION=your-verification-token

# =============================================================================
# SENTRY (Error Monitoring — per-site isolation required)
# Each deployment MUST have its own Sentry project and DSN.
# =============================================================================
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project

# =============================================================================
# VERCEL (Auto-generated by Vercel CLI - do not set manually)
# =============================================================================
# VERCEL_OIDC_TOKEN - auto-generated

